# Database Configuration
POSTGRES_USER=mai_admin
POSTGRES_PASSWORD=mai_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis Configuration
REDIS_PASSWORD=redis_password
REDIS_HOST=redis
REDIS_PORT=6379

# JWT Configuration
JWT_SECRET=mai_jwt_secret_key_for_secure_token_signing_in_development
JWT_EXPIRATION=3600
REFRESH_TOKEN_EXPIRATION=86400

# Spring Profile
SPRING_PROFILES_ACTIVE=docker

# Service Ports
DISCOVERY_SERVER_PORT=8761
API_GATEWAY_PORT=8080
AUTH_SERVICE_PORT=8081
USER_SERVICE_PORT=8082

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
